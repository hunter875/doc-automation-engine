# Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Application Settings
# =============================================================================
PROJECT_NAME=Enterprise RAG System
VERSION=1.0.0
DEBUG=false

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=raguser
DATABASE_PASSWORD=ragpassword
DATABASE_NAME=ragdb

# =============================================================================
# Redis (Message Broker & Cache)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# S3/MinIO (Object Storage)
# =============================================================================
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=rag-documents
S3_REGION=us-east-1

# =============================================================================
# Gemini API
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=3

# =============================================================================
# Extraction Backend (Ollama)
# =============================================================================
EXTRACTION_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=300

# =============================================================================
# Security
# =============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# =============================================================================
# File Upload
# =============================================================================
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=[".pdf",".docx",".doc",".txt",".md",".json",".csv"]

# =============================================================================
# RAG Settings
# =============================================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=100
VECTOR_DIMENSION=1536

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
