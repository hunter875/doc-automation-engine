"""OpenSearch client and operations."""

import logging
from typing import Any, Optional

from opensearchpy import OpenSearch, helpers

from app.core.config import settings
from app.core.exceptions import OpenSearchError

logger = logging.getLogger(__name__)

# OpenSearch client
opensearch_client = OpenSearch(
    hosts=[{"host": settings.OPENSEARCH_HOST, "port": settings.OPENSEARCH_PORT}],
    http_auth=(settings.OPENSEARCH_USER, settings.OPENSEARCH_PASSWORD)
    if settings.OPENSEARCH_USER
    else None,
    use_ssl=settings.OPENSEARCH_USE_SSL,
    verify_certs=False,
    ssl_show_warn=False,
    timeout=30,
    max_retries=3,
    retry_on_timeout=True,
)


# Index mapping for RAG vectors
RAG_INDEX_MAPPING = {
    "settings": {
        "index": {
            "number_of_shards": 3,
            "number_of_replicas": 1,
            "knn": True,
            "knn.algo_param.ef_search": 100,
        }
    },
    "mappings": {
        "properties": {
            "tenant_id": {"type": "keyword"},
            "document_id": {"type": "keyword"},
            "chunk_id": {"type": "keyword"},
            "embedding_model": {"type": "keyword"},
            "content": {"type": "text", "analyzer": "standard"},
            "vector": {
                "type": "knn_vector",
                "dimension": settings.EMBEDDING_DIMENSION,
                "method": {
                    "engine": "nmslib",
                    "space_type": "cosinesimil",
                    "name": "hnsw",
                    "parameters": {"ef_construction": 256, "m": 48},
                },
            },
            "metadata": {
                "type": "object",
                "properties": {
                    "page_number": {"type": "integer"},
                    "chunk_index": {"type": "integer"},
                    "tags": {"type": "keyword"},
                    "file_name": {"type": "keyword"},
                },
            },
            "created_at": {"type": "date"},
        }
    },
}


def create_index(index_name: str = None) -> bool:
    """Create the RAG vectors index if it doesn't exist.

    Args:
        index_name: Name of the index (defaults to settings.OPENSEARCH_INDEX)

    Returns:
        True if index was created or already exists
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    try:
        if not opensearch_client.indices.exists(index=index_name):
            opensearch_client.indices.create(
                index=index_name,
                body=RAG_INDEX_MAPPING,
            )
            logger.info(f"Created OpenSearch index: {index_name}")
            return True
        logger.info(f"OpenSearch index already exists: {index_name}")
        return True
    except Exception as e:
        logger.error(f"Failed to create index: {e}")
        raise OpenSearchError(
            message="Failed to create index",
            original_error=str(e),
        )


def delete_index(index_name: str = None) -> bool:
    """Delete an index.

    Args:
        index_name: Name of the index to delete

    Returns:
        True if deleted successfully
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    try:
        if opensearch_client.indices.exists(index=index_name):
            opensearch_client.indices.delete(index=index_name)
            logger.info(f"Deleted OpenSearch index: {index_name}")
        return True
    except Exception as e:
        logger.error(f"Failed to delete index: {e}")
        raise OpenSearchError(
            message="Failed to delete index",
            original_error=str(e),
        )


def index_document(
    document_id: str,
    tenant_id: str,
    chunk_id: str,
    content: str,
    vector: list[float],
    metadata: Optional[dict[str, Any]] = None,
    index_name: str = None,
) -> str:
    """Index a single document chunk.

    Args:
        document_id: ID of the parent document
        tenant_id: ID of the tenant
        chunk_id: Unique ID for this chunk
        content: Text content of the chunk
        vector: Embedding vector
        metadata: Additional metadata
        index_name: Target index name

    Returns:
        ID of the indexed document
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    doc = {
        "tenant_id": tenant_id,
        "document_id": document_id,
        "chunk_id": chunk_id,
        "content": content,
        "vector": vector,
        "embedding_model": settings.GEMINI_EMBEDDING_MODEL,
        "metadata": metadata or {},
        "created_at": "now",
    }

    try:
        result = opensearch_client.index(
            index=index_name,
            body=doc,
            id=f"{document_id}_{chunk_id}",
            refresh=True,
        )
        return result["_id"]
    except Exception as e:
        logger.error(f"Failed to index document: {e}")
        raise OpenSearchError(
            message="Failed to index document",
            original_error=str(e),
        )


def bulk_index_documents(
    documents: list[dict[str, Any]],
    index_name: str = None,
) -> tuple[int, int]:
    """Bulk index multiple document chunks.

    Args:
        documents: List of document dicts with required fields
        index_name: Target index name

    Returns:
        Tuple of (success_count, error_count)
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    actions = []
    for doc in documents:
        action = {
            "_index": index_name,
            "_id": f"{doc['document_id']}_{doc['chunk_id']}",
            "_source": {
                "tenant_id": doc["tenant_id"],
                "document_id": doc["document_id"],
                "chunk_id": doc["chunk_id"],
                "content": doc["content"],
                "vector": doc["vector"],
                "embedding_model": settings.GEMINI_EMBEDDING_MODEL,
                "metadata": doc.get("metadata", {}),
                "created_at": "now",
            },
        }
        actions.append(action)

    try:
        success, errors = helpers.bulk(
            opensearch_client,
            actions,
            raise_on_error=False,
            refresh=True,
        )
        if errors:
            logger.warning(f"Bulk indexing had {len(errors)} errors")
        return success, len(errors) if isinstance(errors, list) else 0
    except Exception as e:
        logger.error(f"Bulk indexing failed: {e}")
        raise OpenSearchError(
            message="Bulk indexing failed",
            original_error=str(e),
        )


def search_vectors(
    query_vector: list[float],
    tenant_id: str,
    top_k: int = 5,
    index_name: str = None,
    filters: Optional[dict[str, Any]] = None,
) -> list[dict[str, Any]]:
    """Search for similar vectors using k-NN.

    Args:
        query_vector: Query embedding vector
        tenant_id: Tenant ID for filtering
        top_k: Number of results to return
        index_name: Index to search
        filters: Additional filters

    Returns:
        List of matching documents with scores
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    # Build filter query - CRITICAL: Always filter by tenant_id
    must_filters = [{"term": {"tenant_id": tenant_id}}]

    if filters:
        if "document_ids" in filters:
            must_filters.append({"terms": {"document_id": filters["document_ids"]}})
        if "tags" in filters:
            must_filters.append({"terms": {"metadata.tags": filters["tags"]}})

    query = {
        "size": top_k,
        "query": {
            "bool": {
                "must": [
                    {
                        "knn": {
                            "vector": {
                                "vector": query_vector,
                                "k": top_k,
                            }
                        }
                    }
                ],
                "filter": must_filters,
            }
        },
        "_source": ["document_id", "chunk_id", "content", "metadata"],
    }

    try:
        response = opensearch_client.search(index=index_name, body=query)
        results = []
        for hit in response["hits"]["hits"]:
            results.append(
                {
                    "document_id": hit["_source"]["document_id"],
                    "chunk_id": hit["_source"]["chunk_id"],
                    "content": hit["_source"]["content"],
                    "metadata": hit["_source"].get("metadata", {}),
                    "score": hit["_score"],
                }
            )
        return results
    except Exception as e:
        logger.error(f"Vector search failed: {e}")
        raise OpenSearchError(
            message="Vector search failed",
            original_error=str(e),
        )


def hybrid_search(
    query_text: str,
    query_vector: list[float],
    tenant_id: str,
    top_k: int = 5,
    index_name: str = None,
    vector_weight: float = 0.7,
) -> list[dict[str, Any]]:
    """Hybrid search combining k-NN and BM25.

    Args:
        query_text: Text query for BM25
        query_vector: Query embedding for k-NN
        tenant_id: Tenant ID for filtering
        top_k: Number of results
        index_name: Index to search
        vector_weight: Weight for vector score (1 - this = BM25 weight)

    Returns:
        List of matching documents with combined scores
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    query = {
        "size": top_k,
        "query": {
            "bool": {
                "must": [
                    {
                        "bool": {
                            "should": [
                                {
                                    "script_score": {
                                        "query": {"match_all": {}},
                                        "script": {
                                            "source": f"knn_score",
                                            "params": {
                                                "field": "vector",
                                                "query_value": query_vector,
                                                "space_type": "cosinesimil",
                                            },
                                        },
                                    }
                                },
                                {"match": {"content": {"query": query_text, "boost": 1 - vector_weight}}},
                            ]
                        }
                    }
                ],
                "filter": [{"term": {"tenant_id": tenant_id}}],
            }
        },
        "_source": ["document_id", "chunk_id", "content", "metadata"],
    }

    try:
        response = opensearch_client.search(index=index_name, body=query)
        results = []
        for hit in response["hits"]["hits"]:
            results.append(
                {
                    "document_id": hit["_source"]["document_id"],
                    "chunk_id": hit["_source"]["chunk_id"],
                    "content": hit["_source"]["content"],
                    "metadata": hit["_source"].get("metadata", {}),
                    "score": hit["_score"],
                }
            )
        return results
    except Exception as e:
        logger.error(f"Hybrid search failed: {e}")
        raise OpenSearchError(
            message="Hybrid search failed",
            original_error=str(e),
        )


def delete_document_chunks(
    document_id: str,
    tenant_id: str,
    index_name: str = None,
) -> int:
    """Delete all chunks for a document.

    Args:
        document_id: Document ID
        tenant_id: Tenant ID (for safety)
        index_name: Index name

    Returns:
        Number of deleted documents
    """
    index_name = index_name or settings.OPENSEARCH_INDEX

    query = {
        "query": {
            "bool": {
                "must": [
                    {"term": {"document_id": document_id}},
                    {"term": {"tenant_id": tenant_id}},
                ]
            }
        }
    }

    try:
        response = opensearch_client.delete_by_query(
            index=index_name,
            body=query,
            refresh=True,
        )
        return response.get("deleted", 0)
    except Exception as e:
        logger.error(f"Failed to delete document chunks: {e}")
        raise OpenSearchError(
            message="Failed to delete document chunks",
            original_error=str(e),
        )


def check_opensearch_connection() -> bool:
    """Check if OpenSearch connection is healthy.

    Returns:
        True if healthy, False otherwise
    """
    try:
        health = opensearch_client.cluster.health()
        return health["status"] in ["green", "yellow"]
    except Exception:
        return False
