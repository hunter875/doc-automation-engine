"""Document Preview — Browse, search & preview uploaded documents."""

import base64

import sys
from pathlib import Path

import streamlit as st

sys.path.insert(0, str(Path(__file__).parent.parent))
from api_client import (
    get_bytes,
    get_json,
    init_state,
    post_json,
    render_sidebar,
)

st.set_page_config(page_title="Document Preview", page_icon="📄", layout="wide")
init_state()
render_sidebar()

# ─── Header ───────────────────────────────────────────────────
st.title("📄 Document Preview")
st.caption("Xem, tìm kiếm & preview tài liệu đã upload")

if not st.session_state.access_token:
    st.warning("⚠️ Hãy **Login** ở sidebar trước.")
    st.stop()
if not st.session_state.tenant_id:
    st.warning("⚠️ Hãy **chọn Tenant** ở sidebar trước.")
    st.stop()

# ─── Controls ─────────────────────────────────────────────────
ctrl_cols = st.columns([1, 1, 1, 1])
with ctrl_cols[0]:
    page_num = st.number_input("Page", min_value=1, value=1, step=1, key="dp_page")
with ctrl_cols[1]:
    page_size = st.selectbox("Per page", [10, 20, 50], index=1, key="dp_size")
with ctrl_cols[2]:
    status_filter = st.selectbox("Status", ["all", "pending", "processing", "completed", "failed"], key="dp_status")
with ctrl_cols[3]:
    tag_filter = st.text_input("Tag filter", key="dp_tag")

if st.button("🔄 Refresh danh sách", use_container_width=True, key="dp_refresh"):
    params: dict = {"page": page_num, "page_size": page_size}
    if status_filter != "all":
        params["status"] = status_filter
    if tag_filter.strip():
        params["tag"] = tag_filter.strip()

    ok, data = get_json(
        "/api/v1/documents",
        require_tenant=True,
        params=params,
    )
    if ok:
        st.session_state["dp_docs"] = data
    else:
        st.error(data)

# ─── Document list ────────────────────────────────────────────
docs_data = st.session_state.get("dp_docs")

if docs_data:
    items = docs_data.get("items", []) if isinstance(docs_data, dict) else []
    total = docs_data.get("total", len(items)) if isinstance(docs_data, dict) else len(items)

    st.info(f"📚 {total} documents (trang {page_num})")

    if not items:
        st.warning("Không có tài liệu nào.")
    else:
        for doc in items:
            doc_id = str(doc.get("id", ""))
            filename = doc.get("filename", doc.get("file_name", "unknown"))
            doc_status = doc.get("status", "unknown")
            doc_type = doc.get("mime_type", doc.get("content_type", ""))
            chunk_count = doc.get("chunk_count", "?")
            created = doc.get("created_at", "")[:19]
            tags = ", ".join(doc.get("tags", [])) if doc.get("tags") else "-"

            status_icon = {
                "pending": "⏳",
                "processing": "🔄",
                "completed": "✅",
                "failed": "❌",
            }.get(doc_status, "❓")

            with st.expander(f"{status_icon} **{filename}** — `{doc_id[:12]}…`", expanded=False):
                # ── Metadata ──
                meta_cols = st.columns(4)
                meta_cols[0].markdown(f"**Status:** {status_icon} `{doc_status}`")
                meta_cols[1].markdown(f"**Chunks:** `{chunk_count}`")
                meta_cols[2].markdown(f"**Tags:** `{tags}`")
                meta_cols[3].markdown(f"**Created:** `{created}`")

                if doc_type:
                    st.caption(f"MIME: `{doc_type}`")

                st.text(f"Full ID: {doc_id}")

                # ── Action buttons ──
                btn_cols = st.columns(4)

                with btn_cols[0]:
                    if st.button("📋 Chi tiết", key=f"dp_detail_{doc_id}", use_container_width=True):
                        ok, detail = get_json(f"/api/v1/documents/{doc_id}", require_tenant=True)
                        if ok:
                            st.json(detail)
                        else:
                            st.error(detail)

                with btn_cols[1]:
                    if st.button("👁️ Preview", key=f"dp_preview_{doc_id}", use_container_width=True):
                        with st.spinner("Đang tải file…"):
                            ok, content = get_bytes(
                                f"/api/v1/documents/{doc_id}/download",
                                require_tenant=True,
                            )
                        if ok and isinstance(content, bytes):
                            detected_type = doc_type or ""
                            if detected_type.endswith("/pdf") or filename.lower().endswith(".pdf"):
                                # Embed PDF viewer
                                b64 = base64.b64encode(content).decode("utf-8")
                                pdf_html = (
                                    f'<iframe src="data:application/pdf;base64,{b64}" '
                                    f'width="100%" height="700px" type="application/pdf"></iframe>'
                                )
                                st.markdown(pdf_html, unsafe_allow_html=True)
                            elif detected_type.startswith("image/"):
                                st.image(content, caption=filename)
                            elif detected_type.startswith("text/") or filename.endswith((".txt", ".md", ".csv")):
                                try:
                                    text_content = content.decode("utf-8")
                                    st.code(text_content, language=None)
                                except UnicodeDecodeError:
                                    st.warning("Không thể đọc file dạng text.")
                            else:
                                st.info(f"Không hỗ trợ preview inline cho loại `{detected_type}`.")
                                st.download_button(
                                    f"⬇️ Download {filename}",
                                    data=content,
                                    file_name=filename,
                                    key=f"dp_dl_fallback_{doc_id}",
                                )
                        elif not ok:
                            st.error(content)

                with btn_cols[2]:
                    if st.button("⬇️ Download", key=f"dp_download_{doc_id}", use_container_width=True):
                        ok, content = get_bytes(
                            f"/api/v1/documents/{doc_id}/download",
                            require_tenant=True,
                        )
                        if ok and isinstance(content, bytes):
                            st.download_button(
                                f"💾 Save {filename}",
                                data=content,
                                file_name=filename,
                                mime=doc_type or "application/octet-stream",
                                key=f"dp_save_{doc_id}",
                            )
                        elif not ok:
                            st.error(content)

                with btn_cols[3]:
                    if st.button("🔁 Reprocess", key=f"dp_reprocess_{doc_id}", use_container_width=True):
                        ok, data = post_json(
                            f"/api/v1/documents/{doc_id}/reprocess", {}, require_tenant=True,
                        )
                        if ok:
                            st.success(f"✅ Đã gửi reprocess cho `{filename}`")
                        else:
                            st.error(data)

else:
    st.info("Bấm **Refresh danh sách** để load documents.")

# ─── Stats ────────────────────────────────────────────────────
st.markdown("---")
if st.button("📊 Thống kê tài liệu", key="dp_stats"):
    ok, stats = get_json("/api/v1/documents/stats/summary", require_tenant=True)
    if ok:
        if isinstance(stats, dict):
            # Flatten nested dicts (e.g. {"by_status": {"pending": 1, ...}})
            flat: dict = {}
            for k, v in stats.items():
                if isinstance(v, dict):
                    for sub_k, sub_v in v.items():
                        flat[f"{k} {sub_k}"] = sub_v
                else:
                    flat[k] = v
            scols = st.columns(min(len(flat), 5))
            for i, (k, v) in enumerate(flat.items()):
                scols[i % len(scols)].metric(k.replace("_", " ").title(), v)
        st.json(stats)
    else:
        st.error(stats)
