"""Engine 2 — Structured Data Extraction.

Full workflow: Template → Upload PDF → Extract → Review → Aggregate → Export
"""

import json
from typing import Any

import sys
from pathlib import Path

import streamlit as st

sys.path.insert(0, str(Path(__file__).parent.parent))
from api_client import (
    delete_req,
    get_bytes,
    get_json,
    init_state,
    patch_json,
    post_file,
    post_form,
    post_json,
    render_sidebar,
)

st.set_page_config(page_title="Engine 2 — Extraction", page_icon="⚙️", layout="wide")
init_state()
render_sidebar()

# ─── Header ───────────────────────────────────────────────────
st.title("⚙️ Engine 2 — Structured Data Extraction")
st.caption("Template → Upload PDF → AI bóc tách → Review → Aggregate → Export")

if not st.session_state.access_token:
    st.warning("⚠️ Hãy **Login** ở sidebar trước.")
    st.stop()
if not st.session_state.tenant_id:
    st.warning("⚠️ Hãy **chọn Tenant** ở sidebar trước.")
    st.stop()

# ─── Mode selector (top bar) ─────────────────────────────────
mode_col, info_col = st.columns([1, 2])
with mode_col:
    mode = st.selectbox(
        "🎛️ Extraction Mode",
        ["standard", "vision", "fast"],
        index=["standard", "vision", "fast"].index(st.session_state.engine2_mode),
        key="e2_mode_top",
        help="standard: Docling+Flash | vision: Pro native PDF | fast: pdfplumber+Flash",
    )
    st.session_state.engine2_mode = mode
with info_col:
    mode_info = {
        "standard": "📊 **Standard** — Docling parser (GPU) + Gemini Flash. Tốt nhất cho bảng biểu / layout phức tạp.",
        "vision": "👁️ **Vision** — Gemini Pro native PDF. Tốt nhất cho tài liệu scan, ảnh mờ.",
        "fast": "⚡ **Fast** — pdfplumber (CPU) + Gemini Flash. Nhanh nhất cho PDF text thuần.",
    }
    st.info(mode_info[mode])

# ─── Tabs ─────────────────────────────────────────────────────
tmpl_tab, job_tab, review_tab, agg_tab = st.tabs([
    "📋 Templates",
    "📄 Jobs",
    "✅ Review",
    "📊 Aggregate & Export",
])


# ═══════════════════════════════════════════════════════════════
# TAB 1: TEMPLATES
# ═══════════════════════════════════════════════════════════════
with tmpl_tab:
    st.subheader("Quản lý Template")

    # ── Word Template Scanner ─────────────────────────────
    with st.expander("📝 Quét file Word mẫu → Auto-generate Schema", expanded=True):
        st.markdown(
            "Upload file `.docx` chứa các placeholder dạng `{{ten_bien}}`. "
            "Hệ thống quét regex + đọc cấu trúc bảng + (tùy chọn) dùng Gemini để suy luận kiểu dữ liệu."
        )
        wc1, wc2 = st.columns([3, 1])
        with wc1:
            word_file = st.file_uploader("Chọn file Word (.docx)", type=["docx"], key="e2_word_upload")
        with wc2:
            use_llm = st.toggle("🤖 Dùng LLM refine", value=True, key="e2_use_llm",
                                help="Gọi Gemini Flash để suy luận kiểu dữ liệu sub-fields trong bảng")

        if word_file and st.button("🔍 Quét Word Template", type="primary", key="e2_scan_word"):
            import httpx
            with st.spinner("Đang quét placeholders…"):
                url = f"{st.session_state.base_url}/api/v1/extraction/templates/scan-word"
                headers = {"Authorization": f"Bearer {st.session_state.access_token}"}
                files = {"file": (word_file.name, word_file.getvalue(),
                                  "application/vnd.openxmlformats-officedocument.wordprocessingml.document")}
                try:
                    with httpx.Client(timeout=90) as client:
                        resp = client.post(url, files=files, headers=headers,
                                           params={"use_llm": str(use_llm).lower()})
                    if resp.status_code >= 400:
                        st.error(f"{resp.status_code}: {resp.text}")
                    else:
                        st.session_state["e2_scan_result"] = resp.json()
                except Exception as exc:
                    st.error(f"Lỗi kết nối: {exc}")

        # Show scan results & auto-fill
        scan_result = st.session_state.get("e2_scan_result")
        if scan_result:
            stats = scan_result.get("stats", {})
            variables = scan_result.get("variables", [])

            obj_count = stats.get("array_with_object_schema", 0)
            st.success(
                f"✅ **{stats.get('unique_variables', 0)}** biến "
                f"({stats.get('total_placeholders', 0)} lần xuất hiện) — "
                f"{stats.get('paragraphs_scanned', 0)} đoạn văn, "
                f"{stats.get('tables_scanned', 0)} bảng"
                + (f", **{obj_count} array-of-object** (đọc được cấu trúc cột)" if obj_count else "")
            )

            if variables:
                st.markdown("**Các biến tìm được:**")
                for v in variables:
                    type_icon = {"string": "📝", "number": "🔢", "boolean": "✅", "array": "📋"}.get(v["type"], "❓")
                    # Show sub-fields for object arrays
                    items = next(
                        (f.get("items") for f in scan_result.get("schema_definition", {}).get("fields", [])
                         if f.get("name") == v["name"] and "items" in f), None
                    )
                    sub_info = ""
                    if items and items.get("type") == "object":
                        cols = [f"`{sf['name']}` ({sf['type']})" for sf in items.get("fields", [])]
                        sub_info = f"  \n  &nbsp;&nbsp;↳ **object cols:** {', '.join(cols)}"
                    st.markdown(
                        f"- {type_icon} **`{v['name']}`** (`{v['type']}`) — {v['description']}{sub_info}"
                    )

            sc1, sc2 = st.columns(2)
            with sc1:
                if st.button("📥 Điền vào Schema", use_container_width=True, key="e2_fill_schema"):
                    st.session_state["e2_schema_json"] = json.dumps(
                        scan_result["schema_definition"], ensure_ascii=False, indent=2
                    )
                    if scan_result.get("aggregation_rules"):
                        st.session_state["e2_agg_json"] = json.dumps(
                            scan_result["aggregation_rules"], ensure_ascii=False, indent=2
                        )
                    st.success("✅ Đã tự động điền schema & aggregation rules!")
                    st.rerun()
            with sc2:
                if st.button("🗑️ Xóa kết quả quét", use_container_width=True, key="e2_clear_scan"):
                    del st.session_state["e2_scan_result"]
                    st.rerun()

    st.markdown("---")

    t_col1, t_col2 = st.columns(2)

    with t_col1:
        st.markdown("#### Tạo template mới")
        t_name = st.text_input("Tên template", value="Invoice Template", key="e2_t_name")
        t_desc = st.text_input("Mô tả", value="Trích xuất thông tin hóa đơn", key="e2_t_desc")

        # Use scanned schema if available, else default
        default_schema = {
            "fields": [
                {"name": "invoice_number", "type": "string", "description": "Số hóa đơn"},
                {"name": "total_amount", "type": "number", "description": "Tổng tiền"},
                {"name": "invoice_date", "type": "string", "description": "Ngày hóa đơn"},
                {"name": "vendor_name", "type": "string", "description": "Nhà cung cấp"},
            ]
        }
        schema_text = st.text_area(
            "schema_definition (JSON)",
            value=json.dumps(default_schema, ensure_ascii=False, indent=2),
            height=250,
            key="e2_schema_json",
        )

        default_rules = {
            "rules": [
                {"output_field": "total_revenue", "source_field": "total_amount", "method": "SUM", "label": "Tổng doanh thu"},
                {"output_field": "invoice_count", "source_field": "total_amount", "method": "COUNT", "label": "Số lượng"},
            ]
        }
        agg_text = st.text_area(
            "aggregation_rules (JSON, tùy chọn)",
            value=json.dumps(default_rules, ensure_ascii=False, indent=2),
            height=160,
            key="e2_agg_json",
        )

        if st.button("➕ Tạo Template", use_container_width=True, type="primary", key="e2_create_tmpl"):
            try:
                schema_obj = json.loads(schema_text)
                agg_obj = json.loads(agg_text) if agg_text.strip() else None
                payload: dict[str, Any] = {
                    "name": t_name,
                    "description": t_desc,
                    "schema_definition": schema_obj,
                }
                if agg_obj:
                    payload["aggregation_rules"] = agg_obj
                ok, data = post_json("/api/v1/extraction/templates", payload, require_tenant=True)
                if ok:
                    st.success(f"✅ Template tạo thành công! ID: {data.get('id')}")
                    st.session_state.engine2_selected_template_id = str(data["id"])
                    st.json(data)
                else:
                    st.error(data)
            except json.JSONDecodeError as exc:
                st.error(f"JSON không hợp lệ: {exc}")

    with t_col2:
        st.markdown("#### Danh sách template")
        if st.button("🔄 Load templates", use_container_width=True, key="e2_load_tmpl"):
            ok, data = get_json("/api/v1/extraction/templates", require_tenant=True)
            if ok:
                items = data.get("items", []) if isinstance(data, dict) else []
                st.session_state.engine2_templates = items
                st.success(f"Loaded {len(items)} templates")
            else:
                st.error(data)

        if st.session_state.engine2_templates:
            for tmpl in st.session_state.engine2_templates:
                active = "🟢" if tmpl.get("is_active") else "🔴"
                with st.expander(f"{active} {tmpl.get('name')} v{tmpl.get('version', 1)}"):
                    st.text(f"ID: {tmpl.get('id')}")
                    st.text(f"Active: {tmpl.get('is_active')}")
                    fields = tmpl.get("schema_definition", {}).get("fields", [])
                    st.markdown(f"**Fields ({len(fields)}):**")
                    for f in fields:
                        st.text(f"  • {f.get('name')} ({f.get('type')}) — {f.get('description', '')}")

                    if st.button(f"Chọn template này", key=f"e2_sel_{tmpl.get('id')}"):
                        st.session_state.engine2_selected_template_id = str(tmpl["id"])
                        st.success(f"Đã chọn: {tmpl['name']}")
        else:
            st.info("Bấm 'Load templates' để xem danh sách.")

    if st.session_state.engine2_selected_template_id:
        st.success(f"📋 Template đang chọn: `{st.session_state.engine2_selected_template_id}`")


# ═══════════════════════════════════════════════════════════════
# TAB 2: JOBS
# ═══════════════════════════════════════════════════════════════
with job_tab:
    st.subheader("Tạo & Theo dõi Extraction Job")

    active_tpl = st.text_input(
        "Template ID",
        value=st.session_state.engine2_selected_template_id,
        key="e2_job_tpl",
    )
    st.session_state.engine2_selected_template_id = active_tpl.strip()

    j1, j2 = st.columns(2)

    # ── Single job ──────────────────────────────
    with j1:
        st.markdown("#### 📄 Single Job")
        single_file = st.file_uploader("Chọn 1 PDF", type=["pdf"], key="e2_single_pdf")
        if st.button("🚀 Tạo Job", use_container_width=True, type="primary", key="e2_create_job"):
            if not active_tpl:
                st.error("Thiếu Template ID")
            elif not single_file:
                st.error("Chưa chọn file PDF")
            else:
                with st.spinner("Đang upload & tạo job…"):
                    ok, data = post_form(
                        "/api/v1/extraction/jobs",
                        data={"template_id": active_tpl, "mode": st.session_state.engine2_mode},
                        files={"file": (single_file.name, single_file.getvalue(), "application/pdf")},
                        require_tenant=True,
                    )
                if ok:
                    st.success(f"✅ Job created: {data.get('id')}")
                    st.session_state.engine2_last_job_id = str(data["id"])
                    st.json(data)
                else:
                    st.error(data)

    # ── Batch jobs ──────────────────────────────
    with j2:
        st.markdown("#### 📦 Batch Jobs")
        batch_files = st.file_uploader("Chọn nhiều PDF", type=["pdf"], accept_multiple_files=True, key="e2_batch_pdf")
        if st.button("🚀 Tạo Batch", use_container_width=True, key="e2_create_batch"):
            if not active_tpl:
                st.error("Thiếu Template ID")
            elif not batch_files:
                st.error("Chưa chọn file")
            else:
                files_payload = [("files", (f.name, f.getvalue(), "application/pdf")) for f in batch_files]
                with st.spinner(f"Đang tạo batch {len(batch_files)} files…"):
                    ok, data = post_form(
                        "/api/v1/extraction/jobs/batch",
                        data={"template_id": active_tpl, "mode": st.session_state.engine2_mode},
                        files=files_payload,
                        require_tenant=True,
                    )
                if ok:
                    st.success(f"✅ Batch: {data.get('batch_id')}, {data.get('total_files')} files")
                    st.session_state.engine2_last_batch_id = str(data.get("batch_id", ""))
                    st.json(data)
                else:
                    st.error(data)

    # ── From existing document ──────────────────
    with st.expander("📎 Tạo job từ document có sẵn"):
        doc_id = st.text_input("Document ID", key="e2_from_doc_id")
        if st.button("Tạo từ document", key="e2_from_doc_btn"):
            if not doc_id.strip() or not active_tpl:
                st.error("Thiếu document_id hoặc template_id")
            else:
                ok, data = post_json("/api/v1/extraction/jobs/from-document", {
                    "document_id": doc_id.strip(),
                    "template_id": active_tpl,
                    "mode": st.session_state.engine2_mode,
                }, require_tenant=True)
                if ok:
                    st.success(f"✅ Job: {data.get('id')}")
                    st.session_state.engine2_last_job_id = str(data["id"])
                    st.json(data)
                else:
                    st.error(data)

    # ── Job tracking ────────────────────────────
    st.markdown("---")
    st.markdown("#### 🔍 Theo dõi Jobs")

    p1, p2, p3 = st.columns(3)
    with p1:
        if st.button("📋 List all jobs", use_container_width=True, key="e2_list_jobs"):
            ok, data = get_json("/api/v1/extraction/jobs", require_tenant=True)
            if ok:
                items = data.get("items", []) if isinstance(data, dict) else []
                if items:
                    for j in items:
                        status_icon = {"pending": "⏳", "processing": "🔄", "extracted": "📊",
                                       "approved": "✅", "rejected": "❌", "failed": "💥"}.get(j.get("status"), "❓")
                        st.text(f"{status_icon} {j.get('id','')[:8]}… | {j.get('status')} | mode={j.get('extraction_mode')}")
                else:
                    st.info("Chưa có job nào.")
            else:
                st.error(data)

    with p2:
        job_id_poll = st.text_input("Job ID", value=st.session_state.engine2_last_job_id, key="e2_poll_job")
        if st.button("🔍 Chi tiết job", use_container_width=True, key="e2_get_job"):
            if job_id_poll.strip():
                ok, data = get_json(f"/api/v1/extraction/jobs/{job_id_poll.strip()}", require_tenant=True)
                if ok:
                    st.json(data)
                else:
                    st.error(data)

    with p3:
        batch_id_poll = st.text_input("Batch ID", value=st.session_state.engine2_last_batch_id, key="e2_poll_batch")
        if st.button("📊 Batch status", use_container_width=True, key="e2_get_batch"):
            if batch_id_poll.strip():
                ok, data = get_json(f"/api/v1/extraction/jobs/batch/{batch_id_poll.strip()}/status", require_tenant=True)
                if ok:
                    if isinstance(data, dict):
                        col_a, col_b = st.columns(2)
                        with col_a:
                            st.metric("Total", data.get("total", 0))
                            st.metric("Extracted", data.get("extracted", 0))
                            st.metric("Approved", data.get("approved", 0))
                        with col_b:
                            st.metric("Processing", data.get("processing", 0))
                            st.metric("Failed", data.get("failed", 0))
                            st.metric("Progress", f"{data.get('progress_percent', 0):.0f}%")
                    st.json(data)
                else:
                    st.error(data)


# ═══════════════════════════════════════════════════════════════
# TAB 3: REVIEW
# ═══════════════════════════════════════════════════════════════
with review_tab:
    st.subheader("Review kết quả Extraction")

    r1, r2 = st.columns(2)

    with r1:
        st.markdown("#### ✅ Approve")
        approve_jid = st.text_input("Job ID", value=st.session_state.engine2_last_job_id, key="e2_appr_jid")

        # Preview job data before approve
        if approve_jid.strip() and st.button("👁️ Xem data trước", key="e2_preview_approve"):
            ok, data = get_json(f"/api/v1/extraction/jobs/{approve_jid.strip()}", require_tenant=True)
            if ok:
                st.markdown(f"**Status:** `{data.get('status')}`")
                st.markdown("**Extracted data (đã qua Validation Layer):**")
                st.json(data.get("extracted_data", {}))

                # Show validation report if exists
                conf = data.get("confidence_scores", {})
                v_report = conf.get("_validation_report") if conf else None
                if v_report:
                    st.markdown("---")
                    st.markdown("#### 🔍 Validation Report")
                    vc1, vc2, vc3 = st.columns(3)
                    vc1.metric("✅ Completeness", f"{v_report.get('completeness_pct', 0)}%")
                    vc2.metric("Valid fields", f"{v_report.get('valid_fields', 0)}/{v_report.get('total_fields', 0)}")
                    vc3.metric("Auto-corrections", len(v_report.get("auto_corrections", [])))

                    if v_report.get("auto_corrections"):
                        st.markdown("**🔧 Auto-corrections:**")
                        for ac in v_report["auto_corrections"]:
                            st.markdown(
                                f"- `{ac['field']}`: `{ac['original']}` → `{ac['coerced']}` _{ac.get('note', '')}_"
                            )
                    if v_report.get("missing_fields"):
                        st.warning(f"⚠️ Missing fields: {', '.join(v_report['missing_fields'])}")
                    if v_report.get("extra_fields"):
                        st.info(f"ℹ️ Extra fields (not in schema): {', '.join(v_report['extra_fields'])}")
                elif conf:
                    st.markdown("**Confidence:**")
                    st.json({k: v for k, v in conf.items() if k != "_validation_report"})

        approve_notes = st.text_input("Notes", value="OK", key="e2_appr_notes")
        reviewed_json = st.text_area("reviewed_data (JSON, tùy chọn)", value="{}", height=100, key="e2_appr_data")

        if st.button("✅ Approve", use_container_width=True, type="primary", key="e2_approve_btn"):
            try:
                reviewed_obj = json.loads(reviewed_json) if reviewed_json.strip() else None
                payload: dict[str, Any] = {"notes": approve_notes}
                if reviewed_obj and reviewed_obj != {}:
                    payload["reviewed_data"] = reviewed_obj
                ok, data = post_json(
                    f"/api/v1/extraction/review/{approve_jid.strip()}/approve",
                    payload, require_tenant=True,
                )
                if ok:
                    st.success("✅ Job đã approve!")
                    st.json(data)
                else:
                    st.error(data)
            except json.JSONDecodeError as exc:
                st.error(f"JSON lỗi: {exc}")

    with r2:
        st.markdown("#### ❌ Reject")
        reject_jid = st.text_input("Job ID", value=st.session_state.engine2_last_job_id, key="e2_rej_jid")
        reject_notes = st.text_area("Lý do reject", value="Dữ liệu chưa chính xác", height=100, key="e2_rej_notes")

        if st.button("❌ Reject", use_container_width=True, key="e2_reject_btn"):
            ok, data = post_json(
                f"/api/v1/extraction/review/{reject_jid.strip()}/reject",
                {"notes": reject_notes}, require_tenant=True,
            )
            if ok:
                st.success("Đã reject.")
                st.json(data)
            else:
                st.error(data)

        st.markdown("---")
        st.markdown("#### 🔁 Retry job lỗi")
        retry_jid = st.text_input("Job ID retry", value=st.session_state.engine2_last_job_id, key="e2_retry_jid")
        if st.button("🔁 Retry", use_container_width=True, key="e2_retry_btn"):
            ok, data = post_json(f"/api/v1/extraction/jobs/{retry_jid.strip()}/retry", {}, require_tenant=True)
            if ok:
                st.success("✅ Đã retry, job quay lại processing.")
                st.json(data)
            else:
                st.error(data)


# ═══════════════════════════════════════════════════════════════
# TAB 4: AGGREGATE & EXPORT
# ═══════════════════════════════════════════════════════════════
with agg_tab:
    st.subheader("Tổng hợp & Xuất báo cáo")

    a1, a2 = st.columns(2)
    with a1:
        agg_tpl = st.text_input("Template ID", value=st.session_state.engine2_selected_template_id, key="e2_agg_tpl")
        agg_jids = st.text_area(
            "Job IDs (mỗi dòng 1 ID hoặc phân cách bởi dấu phẩy)",
            value=st.session_state.engine2_last_job_id,
            height=120,
            key="e2_agg_jids",
        )
    with a2:
        rpt_name = st.text_input("Tên report", value="Summary Report", key="e2_rpt_name")
        rpt_desc = st.text_input("Mô tả", value="", key="e2_rpt_desc")

    if st.button("📊 Tạo Aggregate Report", use_container_width=True, type="primary", key="e2_create_agg"):
        tokens = [x.strip() for x in agg_jids.replace("\n", ",").split(",") if x.strip()]
        if not agg_tpl.strip() or not tokens:
            st.error("Thiếu template_id hoặc job_ids")
        else:
            ok, data = post_json("/api/v1/extraction/aggregate", {
                "template_id": agg_tpl.strip(),
                "job_ids": tokens,
                "report_name": rpt_name,
                "description": rpt_desc,
            }, require_tenant=True)
            if ok:
                st.success(f"✅ Report: {data.get('id')}")
                st.session_state.engine2_last_report_id = str(data["id"])
                agg_data = data.get("aggregated_data", {})

                # Show aggregation results
                records = agg_data.pop("records", [])
                meta = agg_data.pop("_metadata", {})
                if agg_data:
                    st.markdown("#### 📈 Kết quả tổng hợp")
                    cols = st.columns(min(len(agg_data), 4))
                    for i, (k, v) in enumerate(agg_data.items()):
                        cols[i % len(cols)].metric(k, f"{v:,.0f}" if isinstance(v, (int, float)) else str(v))

                if records:
                    st.markdown(f"#### 📋 Chi tiết ({len(records)} records)")
                    import pandas as pd
                    st.dataframe(pd.DataFrame(records), use_container_width=True)

                st.json(data)
            else:
                st.error(data)

    st.markdown("---")

    # ── List & View reports ──────────────────────
    rpt_col1, rpt_col2 = st.columns(2)
    with rpt_col1:
        if st.button("📋 List reports", use_container_width=True, key="e2_list_rpts"):
            ok, data = get_json("/api/v1/extraction/aggregate", require_tenant=True)
            if ok:
                items = data.get("items", []) if isinstance(data, dict) else []
                for r in items:
                    st.text(f"📊 {r.get('name')} | {r.get('status')} | jobs={r.get('total_jobs')} | {r.get('id','')[:8]}…")
                if not items:
                    st.info("Chưa có report nào.")
            else:
                st.error(data)

    with rpt_col2:
        rpt_id = st.text_input("Report ID", value=st.session_state.engine2_last_report_id, key="e2_rpt_id")
        if st.button("🔍 Chi tiết report", use_container_width=True, key="e2_get_rpt"):
            if rpt_id.strip():
                ok, data = get_json(f"/api/v1/extraction/aggregate/{rpt_id.strip()}", require_tenant=True)
                if ok:
                    st.json(data)
                else:
                    st.error(data)

    # ── Export ───────────────────────────────────
    st.markdown("#### 📥 Export Report")
    exp_rpt = st.text_input("Report ID", value=st.session_state.engine2_last_report_id, key="e2_exp_rpt")
    exp_fmt = st.selectbox("Format", ["excel", "csv", "json"], key="e2_exp_fmt")

    if st.button("📥 Export", use_container_width=True, key="e2_export_btn"):
        if not exp_rpt.strip():
            st.error("Thiếu Report ID")
        elif exp_fmt == "json":
            ok, data = get_json(
                f"/api/v1/extraction/aggregate/{exp_rpt.strip()}/export",
                require_tenant=True, params={"format": "json"},
            )
            if ok:
                st.json(data)
            else:
                st.error(data)
        else:
            ok, content = get_bytes(
                f"/api/v1/extraction/aggregate/{exp_rpt.strip()}/export",
                require_tenant=True, params={"format": exp_fmt},
            )
            if ok and isinstance(content, bytes):
                ext = "xlsx" if exp_fmt == "excel" else "csv"
                mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" if exp_fmt == "excel" else "text/csv"
                st.download_button(
                    f"⬇️ Download {exp_fmt.upper()}",
                    data=content,
                    file_name=f"report.{ext}",
                    mime=mime,
                )
            elif not ok:
                st.error(content)

    # ── Word Template Export (Bước 4) ────────────
    st.markdown("---")
    st.markdown("#### 📄 Export Word (Bơm khuôn Template)")
    st.caption(
        "Upload file `.docx` đã đục lỗ `{{biến}}` + Jinja2 loops. "
        "Server sẽ nhồi dữ liệu tổng hợp vào template → xuất file Word hoàn chỉnh."
    )

    wexp_rpt = st.text_input(
        "Report ID", value=st.session_state.engine2_last_report_id, key="e2_wexp_rpt"
    )
    word_tpl_file = st.file_uploader(
        "Upload Word Template (.docx)", type=["docx"], key="e2_word_tpl_export"
    )

    with st.expander("📝 Hướng dẫn viết template", expanded=False):
        st.markdown("""
**Cú pháp Jinja2 trong Word:**

| Cú pháp | Ý nghĩa |
|---|---|
| `{{ten_don_vi}}` | In giá trị field |
| `{{total_so_vu \\| number_vn}}` | Format số kiểu VN (1.500.000) |
| `{{ngay_bao_cao \\| date_vn}}` | Format ngày VN (ngày 02 tháng 03 năm 2026) |
| `{{today}}` | Ngày hiện tại (DD/MM/YYYY) |

**Loop bảng (trong Word Table):**
```
Hàng 1 bảng: {% for row in records %}
Hàng 2 bảng: {{row.ten_su_co}} | {{row.so_nguoi}} | ...
Hàng 3 bảng: {% endfor %}
```

**Điều kiện:**
```
{% if co_su_co %}Có sự cố{% endif %}
```
        """)

    if word_tpl_file and st.button(
        "📄 Xuất Word", use_container_width=True, type="primary", key="e2_word_export_btn"
    ):
        if not wexp_rpt.strip():
            st.error("Thiếu Report ID")
        else:
            import httpx
            with st.spinner("Đang render Word template…"):
                url = f"{st.session_state.base_url}/api/v1/extraction/aggregate/{wexp_rpt.strip()}/export-word"
                headers = {"Authorization": f"Bearer {st.session_state.access_token}"}
                if st.session_state.tenant_id:
                    headers["X-Tenant-ID"] = st.session_state.tenant_id
                files = {
                    "file": (
                        word_tpl_file.name,
                        word_tpl_file.getvalue(),
                        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                    )
                }
                try:
                    with httpx.Client(timeout=120) as client:
                        resp = client.post(url, files=files, headers=headers)
                    if resp.status_code >= 400:
                        st.error(f"{resp.status_code}: {resp.text}")
                    else:
                        st.success("✅ Word rendered thành công!")
                        st.download_button(
                            "⬇️ Download Word",
                            data=resp.content,
                            file_name=f"report_{wexp_rpt.strip()[:8]}.docx",
                            mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                            key="e2_word_dl",
                        )
                except Exception as exc:
                    st.error(f"Lỗi kết nối: {exc}")
